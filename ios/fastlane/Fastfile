default_platform(:ios)

platform :ios do
  desc "Build, signe et upload vers TestFlight (utilisé par GitHub Actions)"
  lane :release do
    # 1. Authentification App Store Connect via clé API
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_API_KEY_PATH"],
      duration: 1200,
      in_house: false,
    )

    # 2. Keychain temporaire (obligatoire en CI — GitHub Actions n'a pas de keychain par défaut)
    keychain_name = "ci_keychain"
    keychain_password = "ci_keychain_password"
    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 3600,
      lock_when_sleeps: false,
    )

    # 3. Télécharger/créer le certificat de distribution → l'installe dans le keychain CI
    # force: true révoque l'ancien cert avant d'en créer un nouveau
    # → évite "reached maximum number of Distribution certificates" en CI
    cert(
      api_key: api_key,
      team_id: ENV["APPLE_TEAM_ID"],
      keychain_path: "~/Library/Keychains/#{keychain_name}-db",
      keychain_password: keychain_password,
      force: true,
    )

    # 4. Télécharger/créer le profil de provisioning → stocke l'UUID dans ENV["SIGH_UUID"]
    sigh(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      team_id: ENV["APPLE_TEAM_ID"],
      force: true,
    )

    # 5. Appliquer le profil au projet Xcode (passe en signing manuel)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: ENV["APPLE_TEAM_ID"],
      bundle_identifier: ENV["BUNDLE_ID"],
      code_sign_identity: "iPhone Distribution",
      profile_uuid: ENV["SIGH_UUID"],
    )

    # 6. Incrémenter le build number (évite les conflits sur TestFlight)
    increment_build_number(
      xcodeproj: "Runner.xcodeproj",
    )

    # 7. Compiler et signer l'app
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          ENV["BUNDLE_ID"] => ENV["SIGH_UUID"],
        },
        signingStyle: "manual",
        teamID: ENV["APPLE_TEAM_ID"],
      },
      output_directory: "./build",
      output_name: "mentalite.ipa",
    )

    # 8. Upload vers TestFlight
    upload_to_testflight(
      api_key: api_key,
      ipa: "./build/mentalite.ipa",
      skip_waiting_for_build_processing: true,
    )

    UI.success("Build uploadé sur TestFlight avec succès !")
  end
end
