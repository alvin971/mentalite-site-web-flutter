default_platform(:ios)

platform :ios do
  desc "Build, signe et upload vers TestFlight (utilisé par GitHub Actions)"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_KEY_ID"],
      issuer_id: ENV["APP_STORE_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_API_KEY_PATH"],
      duration: 1200,
      in_house: false,
    )

    # Télécharger/créer le certificat de distribution
    cert(
      api_key: api_key,
      team_id: ENV["APPLE_TEAM_ID"],
    )

    # Télécharger/créer le profil de provisionnement (stocke l'UUID dans ENV["SIGH_UUID"])
    sigh(
      api_key: api_key,
      app_identifier: ENV["BUNDLE_ID"],
      team_id: ENV["APPLE_TEAM_ID"],
      force: true,
    )

    # Configurer le projet Xcode avec le bon profil (manuel, pas automatique)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      team_id: ENV["APPLE_TEAM_ID"],
      bundle_identifier: ENV["BUNDLE_ID"],
      code_sign_identity: "iPhone Distribution",
      profile_uuid: ENV["SIGH_UUID"],
    )

    # Incrémenter le build number
    increment_build_number(
      xcodeproj: "Runner.xcodeproj",
    )

    # Compiler et archiver
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      export_method: "app-store",
      export_options: {
        provisioningProfiles: {
          ENV["BUNDLE_ID"] => ENV["SIGH_UUID"],
        },
        signingStyle: "manual",
        teamID: ENV["APPLE_TEAM_ID"],
      },
      output_directory: "./build",
      output_name: "mentalite.ipa",
    )

    # Upload vers TestFlight
    upload_to_testflight(
      api_key: api_key,
      ipa: "./build/mentalite.ipa",
      skip_waiting_for_build_processing: true,
    )

    UI.success("Build uploadé sur TestFlight avec succès !")
  end
end
